{
  "dependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/bun": "^1.3.14",
    "deepmerge": "^4.3.1",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "ignore": "^6.0.2",
    "lint-staged": "^17.1.0",
    "taze": "^19.14.1",
    "tiktoken": "^1.0.22",
    "typescript": "^7.0.2"
  },
  "lint-staged": {
    "*": "biome format --fix --no-errors-on-unmatched"
  },
  "name": "aspen-os",
  "scripts": {
    "check:lint": "biome check --fix .",
    "check:types": "tsc -b",
    "clean": "bunx rimraf --glob \"**/{node_modules,.output,.local,bun.lockb}\"",
    "prepare": "husky",
    "update:deps": "taze -rw --maturity-period 3"
  },
  "workspaces": {
    "catalog": {
      "@types/bun": "^1.3.14",
      "bun": "^1.3.14",
      "drizzle-orm": "^0.45.2",
      "typescript": "^7.0.2",
      "valibot": "^1.4.2"
    },
    "packages": ["./packages/*", "./examples/*", "./docs-www"]
  }
}
