{
  "code_actions_on_format": {
    "source.fixAll.biome": true,
    "source.organizeImports.biome": true
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.coverage",
    "**/.output",
    "**/node_modules",
    "codedb.snapshot",
    "tsconfig.tsbuildinfo"
  ],
  "format_on_save": "on",
  "formatter": {
    "language_server": {
      "name": "biome"
    }
  },
  "language_servers": [
    "!typescript-language-server",
    "!markdownlint",
    "!eslint",
    "!vtsls",
    "typescript-ls",
    "biome",
    "..."
  ],
  "lsp": {
    "vtsls": {
      "binary": {
        "arguments": ["--lsp", "--stdio"],
        "path": "node_modules/.bin/tsc"
      }
    }
  }
}
