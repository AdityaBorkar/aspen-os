{
  "bin": {
    "aspen": "./src/cli/index.ts"
  },
  "build": {
    "bin": {
      "aspen": "./src/cli/index.ts"
    },
    "exports": {
      "./client": {
        "path": "./src/client/index.ts",
        "target": "browser"
      },
      "./server": {
        "path": "./src/server/index.ts",
        "target": "node"
      }
    },
    "files": ["./docs-www", "package.json", "README.md"]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "@better-auth/api-key": "^1.6.23",
    "@better-auth/passkey": "^1.6.23",
    "@opentelemetry/api": "^1.9.1",
    "@orpc/server": "^1.14.8",
    "better-auth": "^1.6.23",
    "bun": "catalog:",
    "commander": "^13.1.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "catalog:",
    "nanoid": "^5.1.16",
    "pg": "^8.22.0",
    "pg-boss": "^10.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "valibot": "catalog:",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/pg": "^8.20.0",
    "deepmerge": "^4.3.1",
    "typescript": "catalog:"
  },
  "exports": {
    "./client": "./src/client/index.ts",
    "./server": "./src/server/index.ts"
  },
  "files": ["./docs-www", "package.json", "README.md", "./src"],
  "name": "@aspen-os/framework",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "bun run ../../scripts/build.ts",
    "check:lint": "biome check --fix .",
    "check:types": "tsc -b",
    "publish": "bun run build && bun publish"
  },
  "type": "module",
  "version": "0.1.0"
}
